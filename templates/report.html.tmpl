<!doctype html>
<!--
  idstack — per-skill report skeleton.

  Skills emit one file matching this shape per run, at:
    .idstack/exports/<course-slug>/<skill>.html

  Placeholders are described in templates/report-format.md (the content contract).
  This file is the visual contract; report-format.md is the data contract. Both
  must stay in sync.

  Skills do NOT use a templating engine. They fill this shape in by writing the
  HTML directly with the Write tool, substituting their own values for each
  {{placeholder}}. Comments below mark which sections are required vs optional.
-->
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{skill_title}} — {{project_name}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Public+Sans:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap">
  <link rel="stylesheet" href="assets/idstack.css">
</head>
<body class="idstack-report">

  <header class="report-header">
    <p class="kicker">idstack · {{skill_name}}</p>
    <h1>{{skill_title}}</h1>
    <p class="meta">
      <span class="course">{{project_name}}</span>
      <span class="sep">·</span>
      <time datetime="{{iso_timestamp}}">{{human_timestamp}}</time>
      <span class="sep">·</span>
      <span class="run-id">run {{run_id}}</span>
      <!-- Optional: <span class="sep">·</span><span class="mode">mode: {{mode}}</span> -->
    </p>
  </header>

  <main>

    <section class="summary">
      <h2>Summary</h2>
      <p>{{summary_paragraph_2_to_3_sentences}}</p>
      <!-- Optional one-line scoreboard for skills that produce numeric output:
      <p class="scoreboard mono">Quality 62/100 · Accessibility 71/100 · Confidence 4/5</p>
      -->
    </section>

    <section class="findings">
      <h2>Findings</h2>

      <!-- Repeat <article class="finding"> per finding. Order: critical → warning → info,
           then by impact within severity. Stable ids: <dimension>-<n>. -->

      <article class="finding sev-{{severity}}" id="{{finding_id}}">
        <header>
          <span class="sev-badge sev-{{severity}}">{{severity}}</span>
          <span class="tier-badge tier-{{tier}}">{{tier}}</span>
          <h3>Finding {{finding_id}}: {{finding_title}}</h3>
        </header>
        <dl>
          <dt>What we saw</dt>
          <dd>{{observation_html}}</dd>
          <dt>What the evidence says</dt>
          <dd>{{evidence_html}} <cite class="citation">[{{domain}}-{{n}}] [{{tier}}]</cite></dd>
          <dt>Why it matters</dt>
          <dd>{{why_it_matters_html}}</dd>
          <dt>Consider</dt>
          <dd>{{suggestion_html}}</dd>
        </dl>
      </article>

      <!-- ... more <article class="finding"> ... -->

    </section>

    <section class="recommendations">
      <h2>Top recommendations</h2>
      <ol>
        <li><strong>{{action}}</strong> <cite class="citation">[{{domain}}-{{n}}] [{{tier}}]</cite> — {{one_line_why}}</li>
        <!-- 3–5 items, ordered by impact -->
      </ol>
    </section>

    <!-- Optional: skill-specific extra sections go here (e.g. needs-analysis
         adds "Training justification" + "Expertise-fit read"). Use <section>
         with a clear <h2> heading. -->

    <section class="limitations">
      <h2>Limitations</h2>
      {{limitations_html}}
    </section>

    <section class="next-steps">
      <h2>Next steps</h2>
      {{next_steps_html}}
    </section>

  </main>

  <footer class="report-footer">
    <p>Generated by <code>/idstack:{{skill_name}}</code> · idstack v{{idstack_version}}</p>
    <p><a href="index.html">← back to course dashboard</a></p>
  </footer>

</body>
</html>
