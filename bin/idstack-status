#!/usr/bin/env bash
# Course health dashboard. Reads .idstack/timeline.jsonl and prints a summary.
# Usage: idstack-status
#        idstack-status --readiness    (pre-export readiness table only)
# Shows: project name, skills completed, quality score trend, dimensions, next step.
#
# Readiness thresholds (the bar a course must clear to be reported READY):
#   READY_QUALITY_MIN          = 70   (quality_review.overall_score must be >=)
#   READY_ACCESS_MIN           = 80   (accessibility_review.score.overall must be >=)
#   READY_RED_CRITICAL_MAX     = 0    (red_team_audit.findings_summary.critical must be <=)
#   READY_LEVEL_A_VIOLATIONS_OK = false (any WCAG Level-A violation forces NOT-READY)
# Tune by editing the constants in the readiness python block below.
READY_QUALITY_MIN=70
READY_ACCESS_MIN=80
READY_RED_CRITICAL_MAX=0

READINESS_ONLY=0
[ "$1" = "--readiness" ] && READINESS_ONLY=1

TIMELINE=".idstack/timeline.jsonl"
LEARNINGS=".idstack/learnings.jsonl"
MANIFEST=".idstack/project.json"

# Project name
PROJECT_NAME="unknown"
if [ -f "$MANIFEST" ] && command -v python3 &>/dev/null; then
  PROJECT_NAME=$(python3 -c "
import json
try:
    d = json.load(open('$MANIFEST'))
    print(d.get('project_name', d.get('needs_analysis', {}).get('project_name', 'unknown')))
except: print('unknown')
" 2>/dev/null) || PROJECT_NAME="unknown"
fi

if [ "$READINESS_ONLY" -eq 0 ]; then
  echo "=============================="
  echo "  idstack course status"
  echo "=============================="
  echo ""
fi

if [ ! -f "$TIMELINE" ]; then
  if [ "$READINESS_ONLY" -eq 1 ]; then
    echo "No timeline data. Run pipeline skills first."
  else
    echo "No course data yet."
    echo "Run /needs-analysis to start a new course, or /course-import to bring in an existing one."
  fi
  exit 0
fi

if ! command -v python3 &>/dev/null; then
  echo "Project: $PROJECT_NAME"
  echo ""
  TOTAL=$(wc -l < "$TIMELINE" 2>/dev/null | tr -d ' ')
  echo "Timeline: $TOTAL events"
  echo "(Install python3 for score trends and dimension analysis)"
  exit 0
fi

if [ "$READINESS_ONLY" -eq 0 ]; then
python3 -c "
import json, sys

lines = open('$TIMELINE').readlines()[-200:]
events = []
for line in lines:
    try:
        events.append(json.loads(line))
    except:
        pass

if not events:
    print('No valid timeline entries.')
    sys.exit(0)

print(f'Project: $PROJECT_NAME')
print()

# Skills completed
skills_run = {}
for e in events:
    s = e.get('skill', '?')
    if e.get('event') == 'completed':
        skills_run[s] = skills_run.get(s, 0) + 1

print('Skills completed:')
pipeline = [
    'needs-analysis', 'learning-objectives', 'assessment-design',
    'course-import', 'course-builder', 'course-quality-review',
    'accessibility-review', 'red-team', 'course-export'
]
for s in pipeline:
    count = skills_run.get(s, 0)
    marker = 'x' if count > 0 else ' '
    suffix = f' ({count}x)' if count > 1 else ''
    print(f'  [{marker}] /{s}{suffix}')
print()

# Quality score trend
quality_reviews = [e for e in events if e.get('skill') == 'course-quality-review' and 'score' in e]
if quality_reviews:
    trend = ' -> '.join(str(r['score']) for r in quality_reviews[-5:])
    print(f'Quality trend: {trend}')
    last = quality_reviews[-1]
    dims = last.get('dimensions', {})
    if dims:
        tp = dims.get('teaching_presence', '?')
        sp = dims.get('social_presence', '?')
        cp = dims.get('cognitive_presence', '?')
        print(f'Last presence scores: Teaching={tp}/10  Social={sp}/10  Cognitive={cp}/10')
        cd = dims.get('cross_domain', {})
        if cd:
            print(f'Cross-domain: CogLoad={cd.get(\"cognitive_load\",\"?\")}/10  Multimedia={cd.get(\"multimedia\",\"?\")}/10  Feedback={cd.get(\"feedback_quality\",\"?\")}/10')
    print()

# Pipeline progression
completed = set(skills_run.keys())
pipeline_order = [
    ('needs-analysis', 'learning-objectives'),
    ('learning-objectives', 'assessment-design'),
    ('assessment-design', 'course-builder'),
    ('course-builder', 'course-quality-review'),
    ('course-quality-review', 'accessibility-review'),
    ('accessibility-review', 'red-team'),
    ('red-team', 'course-export'),
]
next_skill = None
for prev, nxt in pipeline_order:
    if prev in completed and nxt not in completed:
        next_skill = nxt
        break
if not next_skill and 'needs-analysis' not in completed and 'course-import' not in completed:
    next_skill = 'needs-analysis'

if next_skill:
    print(f'Suggested next: /{next_skill}')
    print()
" 2>/dev/null || echo "Error reading timeline."
fi

# Learnings count
if [ -f "$LEARNINGS" ] && [ "$READINESS_ONLY" -eq 0 ]; then
  LEARN_COUNT=$(wc -l < "$LEARNINGS" 2>/dev/null | tr -d ' ')
  [ "$LEARN_COUNT" -gt 0 ] 2>/dev/null && echo "Learnings: $LEARN_COUNT discoveries stored"
fi

# Reports — list every per-skill HTML report present under the course's export
# folder, plus the index.html dashboard. The dashboard is what the designer
# opens in a browser; the manifest is for the system.
if [ -d ".idstack/exports" ] && [ "$READINESS_ONLY" -eq 0 ]; then
  # Find the course folder. Prefer the slug derived from project_name; fall
  # back to the only subfolder if exactly one exists (handles legacy folders
  # left behind after a course rename).
  COURSE_DIR=""
  if [ -n "$PROJECT_NAME" ] && [ "$PROJECT_NAME" != "unknown" ] && [ -x "$(dirname "$0")/idstack-slugify" ]; then
    _SLUG=$("$(dirname "$0")/idstack-slugify" "$PROJECT_NAME" 2>/dev/null || true)
    [ -n "$_SLUG" ] && [ -d ".idstack/exports/$_SLUG" ] && COURSE_DIR=".idstack/exports/$_SLUG"
  fi
  if [ -z "$COURSE_DIR" ]; then
    SUBDIR_COUNT=$(find .idstack/exports -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    if [ "$SUBDIR_COUNT" = "1" ]; then
      COURSE_DIR=$(find .idstack/exports -mindepth 1 -maxdepth 1 -type d 2>/dev/null | head -1)
    fi
  fi

  if [ -n "$COURSE_DIR" ]; then
    REPORT_COUNT=$(find "$COURSE_DIR" -maxdepth 1 -name '*.html' -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "$REPORT_COUNT" -gt 0 ] 2>/dev/null; then
      echo ""
      echo "Reports (open in a browser for the human view):"
      if [ -f "$COURSE_DIR/index.html" ]; then
        echo "  $COURSE_DIR/index.html  <-- course dashboard, start here"
      fi
      for f in "$COURSE_DIR"/*.html; do
        [ "$f" = "$COURSE_DIR/index.html" ] && continue
        [ -f "$f" ] && echo "  $f"
      done
      # LMS packages
      for f in "$COURSE_DIR"/course-export.imscc "$COURSE_DIR"/scorm-export.zip; do
        [ -f "$f" ] && echo "  $f  <-- LMS package"
      done
    fi
  fi
fi

# Readiness table (shown with --readiness flag or appended to full output)
if [ "$READINESS_ONLY" -eq 1 ] || [ -f "$MANIFEST" ]; then
  python3 -c "
import json, sys, os

manifest_file = '$MANIFEST'
timeline_file = '$TIMELINE'
readiness_only = $READINESS_ONLY
READY_QUALITY_MIN     = $READY_QUALITY_MIN
READY_ACCESS_MIN      = $READY_ACCESS_MIN
READY_RED_CRITICAL_MAX = $READY_RED_CRITICAL_MAX

if not os.path.exists(timeline_file):
    if readiness_only:
        print('No timeline data. Run pipeline skills first.')
    sys.exit(0)

# Read timeline for completed skills
events = []
for line in open(timeline_file):
    try: events.append(json.loads(line))
    except: pass

completed = set()
for e in events:
    if e.get('event') == 'completed':
        completed.add(e.get('skill', ''))

# Read manifest for scores
manifest = {}
if os.path.exists(manifest_file):
    try: manifest = json.load(open(manifest_file))
    except: pass

# Build readiness table
quality_score = manifest.get('quality_review', {}).get('overall_score', 0)
quality_reviewed = 'course-quality-review' in completed
red_team = manifest.get('red_team_audit', {})
red_critical = red_team.get('findings_summary', {}).get('critical', 0)
red_reviewed = 'red-team' in completed
access = manifest.get('accessibility_review', {})
access_score = access.get('score', {}).get('overall', 0)
access_reviewed = 'accessibility-review' in completed
# Level-A WCAG violations force NOT-READY regardless of overall score.
wcag_violations = access.get('wcag_violations', []) or []
level_a_violations = [v for v in wcag_violations if isinstance(v, dict) and v.get('level') == 'A']

# Per-skill tier: NOT RUN / NEEDS-WORK / READY
def quality_tier():
    if not quality_reviewed: return 'NOT RUN'
    return 'READY' if quality_score >= READY_QUALITY_MIN else 'NEEDS-WORK'

def red_tier():
    if not red_reviewed: return 'NOT RUN'
    return 'READY' if red_critical <= READY_RED_CRITICAL_MAX else 'NEEDS-WORK'

def access_tier():
    if not access_reviewed: return 'NOT RUN'
    if access_score >= READY_ACCESS_MIN and not level_a_violations:
        return 'READY'
    return 'NEEDS-WORK'

if readiness_only:
    print()
print('─── Course Readiness ───')
print()
q_status = quality_tier()
r_status = red_tier()
a_status = access_tier()
print(f'  Quality Review:       {q_status:<11} Score: {quality_score}/100  (READY threshold: {READY_QUALITY_MIN})')
print(f'  Red Team Audit:       {r_status:<11} Critical: {red_critical}  (READY threshold: <= {READY_RED_CRITICAL_MAX})')
a_extra = f'  WCAG Level-A violations: {len(level_a_violations)}' if level_a_violations else ''
print(f'  Accessibility Review: {a_status:<11} Score: {access_score}/100  (READY threshold: {READY_ACCESS_MIN}{a_extra})')
print()

# Overall verdict — strict gate. Any unmet condition produces NOT-READY,
# with itemized reasons. Missing reviews produce INCOMPLETE.
def verdict():
    missing = []
    if not quality_reviewed: missing.append('/course-quality-review')
    if not red_reviewed:     missing.append('/red-team')
    if not access_reviewed:  missing.append('/accessibility-review')
    if missing:
        return f\"INCOMPLETE (run {', '.join(missing)})\"

    issues = []
    if quality_score < READY_QUALITY_MIN:
        issues.append(f'quality score {quality_score} < {READY_QUALITY_MIN}')
    if red_critical > READY_RED_CRITICAL_MAX:
        issues.append(f'{red_critical} critical red-team finding(s)')
    if access_score < READY_ACCESS_MIN:
        issues.append(f'accessibility score {access_score} < {READY_ACCESS_MIN}')
    if level_a_violations:
        issues.append(f'{len(level_a_violations)} WCAG Level-A violation(s)')
    if not issues:
        return 'READY TO EXPORT'
    return f\"NOT-READY ({', '.join(issues)})\"

print(f'  Verdict: {verdict()}')
print()
" 2>/dev/null || true
fi
