#!/usr/bin/env bash
# Append one timeline event to .idstack/timeline.jsonl.
# Usage: idstack-timeline-log '{"skill":"course-quality-review","event":"completed","score":72}'
# Injects "ts" field automatically. Creates .idstack/ if needed.
# Exit 0 always — never blocks the calling skill.

set -e

JSON_ARG="${1:-}"
[ -z "$JSON_ARG" ] && exit 0

IDSTACK_DIR=".idstack"
TIMELINE="$IDSTACK_DIR/timeline.jsonl"

mkdir -p "$IDSTACK_DIR" 2>/dev/null || exit 0

TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# Use python3 for safe JSON serialization (injects ts field)
if command -v python3 &>/dev/null; then
  LINE=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.argv[1])
    d['ts'] = '$TS'
    print(json.dumps(d))
except Exception:
    # Fallback: wrap raw input with timestamp
    print(json.dumps({'raw': sys.argv[1], 'ts': '$TS'}))
" "$JSON_ARG" 2>/dev/null) || LINE="{\"raw\":\"error\",\"ts\":\"$TS\"}"
else
  # No python3: best-effort bash append (no JSON validation)
  LINE=$(echo "$JSON_ARG" | sed "s/}$/,\"ts\":\"$TS\"}/")
fi

echo "$LINE" >> "$TIMELINE" 2>/dev/null || true
