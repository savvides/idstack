#!/usr/bin/env bash
# Generate SKILL.md files from .tmpl templates.
# Usage: idstack-gen-skills [--dry-run]
#
# Reads each skills/{skill}/SKILL.md.tmpl, replaces {{PREAMBLE}} with
# templates/preamble.md contents, writes skills/{skill}/SKILL.md.
# Adds auto-generated header to each output file.

set -e

IDSTACK_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PREAMBLE="$IDSTACK_DIR/templates/preamble.md"
MANIFEST_SCHEMA="$IDSTACK_DIR/templates/manifest-schema.md"
DRY_RUN=0
GENERATED=0
ERRORS=0

[ "$1" = "--dry-run" ] && DRY_RUN=1

if [ ! -f "$PREAMBLE" ]; then
  echo "ERROR: templates/preamble.md not found at $PREAMBLE" >&2
  exit 1
fi

if [ ! -f "$MANIFEST_SCHEMA" ]; then
  echo "ERROR: templates/manifest-schema.md not found at $MANIFEST_SCHEMA" >&2
  exit 1
fi

HEADER="<!-- AUTO-GENERATED from SKILL.md.tmpl -- do not edit directly -->"
HEADER2="<!-- Edit the .tmpl file instead. Regenerate: bin/idstack-gen-skills -->"

for tmpl in "$IDSTACK_DIR"/skills/*/SKILL.md.tmpl; do
  [ -f "$tmpl" ] || continue
  skill_dir="$(dirname "$tmpl")"
  skill_name="$(basename "$skill_dir")"
  output="$skill_dir/SKILL.md"

  # Read template
  tmpl_content=$(cat "$tmpl")

  # Check for {{PREAMBLE}} placeholder
  if ! echo "$tmpl_content" | grep -q '{{PREAMBLE}}'; then
    echo "  SKIP: $skill_name/SKILL.md.tmpl (no {{PREAMBLE}} placeholder)"
    continue
  fi

  # Read preamble content
  preamble_content=$(cat "$PREAMBLE")

  # Build output: extract YAML frontmatter, inject header after it, then replace placeholder.
  # The awk pass below handles frontmatter detection and header injection independently —
  # no need to pre-extract the frontmatter text.

  # Use awk to do the replacement properly
  result=$(awk -v header="$HEADER" -v header2="$HEADER2" -v preamble_file="$PREAMBLE" -v schema_file="$MANIFEST_SCHEMA" '
    BEGIN { after_frontmatter = 0; frontmatter_count = 0 }
    /^---$/ {
      frontmatter_count++
      print
      if (frontmatter_count == 2) {
        print header
        print header2
        print ""
      }
      next
    }
    /\{\{PREAMBLE\}\}/ {
      while ((getline line < preamble_file) > 0) print line
      close(preamble_file)
      next
    }
    /\{\{MANIFEST_SCHEMA\}\}/ {
      while ((getline line < schema_file) > 0) print line
      close(schema_file)
      next
    }
    { print }
  ' "$tmpl")

  if [ "$DRY_RUN" -eq 1 ]; then
    if [ -f "$output" ]; then
      current=$(cat "$output")
      if [ "$result" != "$current" ]; then
        echo "  STALE: $skill_name/SKILL.md (would be updated)"
        ERRORS=$((ERRORS + 1))
      else
        echo "  OK: $skill_name/SKILL.md (up to date)"
      fi
    else
      echo "  MISSING: $skill_name/SKILL.md (would be created)"
      ERRORS=$((ERRORS + 1))
    fi
  else
    echo "$result" > "$output"
    echo "  GENERATED: $skill_name/SKILL.md"
  fi
  GENERATED=$((GENERATED + 1))
done

if [ "$GENERATED" -eq 0 ]; then
  echo "No .tmpl files found."
  exit 1
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo ""
  echo "$GENERATED templates checked. $ERRORS stale."
  if [ "$ERRORS" -gt 0 ]; then exit 1; fi
else
  echo ""
  echo "$GENERATED skills generated."
fi
