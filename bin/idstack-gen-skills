#!/usr/bin/env bash
# Generate SKILL.md files from .tmpl templates, for one or more CLI targets.
#
# Usage:
#   idstack-gen-skills [--target {claude|codex|all}] [--dry-run]
#
# Targets:
#   claude:           writes skills/<name>/SKILL.md (the existing Claude Code layout)
#   codex:            writes dist/codex/skills/idstack-<name>/SKILL.md (Codex CLI layout)
#                     plus repo-root AGENTS.md (memory file generated from
#                     templates/agent-context.md). Skills are installed via per-skill
#                     symlinks into $CODEX_HOME/skills/idstack-<name>/ at setup time —
#                     Codex auto-discovers skills there. The frontmatter
#                     `allowed-tools:` block is stripped — Codex has no per-skill
#                     allowlist.
#   all (default):    both targets
#
# Source of truth is unchanged: skills/<name>/SKILL.md.tmpl with {{PREAMBLE}} and
# {{MANIFEST_SCHEMA}} placeholders. The preamble defines the AskUserQuestion / Skill
# / Agent concepts portably so skill bodies don't need per-target text substitution.

set -e

IDSTACK_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PREAMBLE="$IDSTACK_DIR/templates/preamble.md"
MANIFEST_SCHEMA="$IDSTACK_DIR/templates/manifest-schema.md"
DRY_RUN=0
TARGET="all"
GENERATED=0
ERRORS=0

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --target)  TARGET="$2"; shift 2 ;;
    --target=*) TARGET="${1#--target=}"; shift ;;
    -h|--help)
      # Print the header comment block (line 2 through first blank line) as help.
      # Pattern-based range — robust to header edits.
      sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    *) echo "Unknown argument: $1" >&2; exit 2 ;;
  esac
done

case "$TARGET" in
  claude|codex|all) ;;
  *) echo "ERROR: --target must be one of: claude, codex, all (got: $TARGET)" >&2; exit 2 ;;
esac

if [ ! -f "$PREAMBLE" ]; then
  echo "ERROR: templates/preamble.md not found at $PREAMBLE" >&2
  exit 1
fi

if [ ! -f "$MANIFEST_SCHEMA" ]; then
  echo "ERROR: templates/manifest-schema.md not found at $MANIFEST_SCHEMA" >&2
  exit 1
fi

# HTML report assets — skills read these at runtime to write branded reports
# into .idstack/exports/<course-slug>/. Missing files would silently break
# every skill that produces a report, so fail loud here.
REPORT_HTML_TMPL="$IDSTACK_DIR/templates/report.html.tmpl"
INDEX_HTML_TMPL="$IDSTACK_DIR/templates/index.html.tmpl"
REPORT_CSS="$IDSTACK_DIR/templates/assets/idstack.css"

for f in "$REPORT_HTML_TMPL" "$INDEX_HTML_TMPL" "$REPORT_CSS"; do
  if [ ! -f "$f" ]; then
    echo "ERROR: report asset not found at ${f#$IDSTACK_DIR/}" >&2
    exit 1
  fi
done

HEADER="<!-- AUTO-GENERATED from SKILL.md.tmpl -- do not edit directly -->"
HEADER2="<!-- Edit the .tmpl file instead. Regenerate: bin/idstack-gen-skills -->"

# render_template <tmpl_path> <output_path> <target>
# Substitutes {{PREAMBLE}} and {{MANIFEST_SCHEMA}}, injects auto-generated header
# after frontmatter, and (for codex target) strips the `allowed-tools:` block.
render_template() {
  local tmpl="$1"
  local output="$2"
  local target="$3"
  local skill_name
  skill_name="$(basename "$(dirname "$tmpl")")"

  if ! grep -q '{{PREAMBLE}}' "$tmpl"; then
    echo "  SKIP: $skill_name/SKILL.md.tmpl (no {{PREAMBLE}} placeholder)"
    return 1
  fi

  local result
  result=$(awk -v header="$HEADER" -v header2="$HEADER2" \
               -v preamble_file="$PREAMBLE" -v schema_file="$MANIFEST_SCHEMA" \
               -v target="$target" '
    BEGIN {
      after_frontmatter = 0
      frontmatter_count = 0
      in_allowed_tools = 0
    }
    /^---$/ {
      frontmatter_count++
      print
      if (frontmatter_count == 2) {
        print header
        print header2
        print ""
      }
      in_allowed_tools = 0
      next
    }
    # Strip the `allowed-tools:` block from frontmatter for codex target.
    # The block runs from `allowed-tools:` until the next non-indented sibling
    # key or the closing `---`. Match is case-insensitive and rejects leading
    # whitespace so a stray indented duplicate cannot bypass the strip.
    frontmatter_count == 1 && target == "codex" {
      if (in_allowed_tools) {
        if ($0 ~ /^[^ \t-]/) {
          in_allowed_tools = 0
          # fall through to print this line (the next sibling key)
        } else {
          next  # still inside allowed-tools list, skip
        }
      }
      if (tolower($0) ~ /^allowed-tools:[[:space:]]*$/) {
        in_allowed_tools = 1
        next
      }
    }
    /\{\{PREAMBLE\}\}/ {
      while ((getline line < preamble_file) > 0) print line
      close(preamble_file)
      next
    }
    /\{\{MANIFEST_SCHEMA\}\}/ {
      while ((getline line < schema_file) > 0) print line
      close(schema_file)
      next
    }
    { print }
  ' "$tmpl")

  if [ "$DRY_RUN" -eq 1 ]; then
    if [ -f "$output" ]; then
      local current
      current=$(cat "$output")
      if [ "$result" != "$current" ]; then
        echo "  STALE: ${output#$IDSTACK_DIR/} (would be updated)"
        ERRORS=$((ERRORS + 1))
      else
        echo "  OK: ${output#$IDSTACK_DIR/} (up to date)"
      fi
    else
      echo "  MISSING: ${output#$IDSTACK_DIR/} (would be created)"
      ERRORS=$((ERRORS + 1))
    fi
  else
    mkdir -p "$(dirname "$output")"
    echo "$result" > "$output"
    echo "  GENERATED: ${output#$IDSTACK_DIR/}"
  fi
  return 0
}

# render_target <target> — iterate templates and dispatch render_template
render_target() {
  local target="$1"
  echo "=== target: $target ==="
  for tmpl in "$IDSTACK_DIR"/skills/*/SKILL.md.tmpl; do
    [ -f "$tmpl" ] || continue
    local skill_dir skill_name output
    skill_dir="$(dirname "$tmpl")"
    skill_name="$(basename "$skill_dir")"

    case "$target" in
      claude) output="$skill_dir/SKILL.md" ;;
      codex)  output="$IDSTACK_DIR/dist/codex/skills/idstack-$skill_name/SKILL.md" ;;
    esac

    if render_template "$tmpl" "$output" "$target"; then
      GENERATED=$((GENERATED + 1))
    fi
  done

  # Codex target: also emit AGENTS.md (memory file) and marketplace.json (plugin
  # manifest). Renders in dry-run too, comparing against on-disk content so drift
  # is visible to the smoke test.
  if [ "$target" = "codex" ]; then
    render_codex_assets
  fi
}

# render_codex_assets — emit AGENTS.md at the repo root.
# AGENTS.md describes idstack for Codex sessions running inside the idstack repo
# itself (devs working on idstack). End-users who install idstack via setup get
# per-skill symlinks at $CODEX_HOME/skills/idstack-<name>/ which Codex auto-
# discovers; no marketplace.json or plugin manifest is needed for that path.
#
# Honors $DRY_RUN: renders to a tempfile and reports STALE/OK without touching
# the on-disk file (matches the SKILL.md dry-run contract).
render_codex_assets() {
  local agents_src="$IDSTACK_DIR/templates/agent-context.md"
  local agents_dst="$IDSTACK_DIR/AGENTS.md"

  if [ -f "$agents_src" ]; then
    if [ "$DRY_RUN" -eq 1 ]; then
      if [ -f "$agents_dst" ] && cmp -s "$agents_src" "$agents_dst"; then
        echo "  OK: AGENTS.md (up to date)"
      else
        echo "  STALE: AGENTS.md (would be updated)"
        ERRORS=$((ERRORS + 1))
      fi
    else
      cp "$agents_src" "$agents_dst"
      echo "  GENERATED: AGENTS.md"
    fi
  fi
}

# Dispatch
case "$TARGET" in
  claude) render_target claude ;;
  codex)  render_target codex ;;
  all)    render_target claude; render_target codex ;;
esac

if [ "$GENERATED" -eq 0 ]; then
  echo "No .tmpl files found."
  exit 1
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo ""
  echo "$GENERATED templates checked. $ERRORS stale."
  if [ "$ERRORS" -gt 0 ]; then exit 1; fi
else
  echo ""
  echo "$GENERATED skill files generated (target: $TARGET)."
fi
