#!/usr/bin/env bash
# Migrate .idstack/project.json to the latest schema version.
# Reads the manifest, applies any needed migrations, writes it back, and
# outputs the (possibly updated) JSON to stdout.
# Prints "MIGRATED <from> <to>" to stderr when a migration is applied.
# If the file does not exist, prints nothing and exits 0.
# If python3 is unavailable, falls back to cat (graceful degradation).

set -e

LATEST_VERSION="1.3"

MANIFEST="${1:-.idstack/project.json}"

# Nothing to do if no manifest exists
[ -f "$MANIFEST" ] || exit 0

# Require python3 for JSON manipulation; fall back to cat if missing
if ! command -v python3 &>/dev/null; then
  cat "$MANIFEST"
  exit 0
fi

VERSION=$(python3 -c "
import json, sys
try:
    with open('$MANIFEST') as f:
        data = json.load(f)
    print(data.get('version', ''))
except Exception:
    sys.exit(1)
" 2>/dev/null) || { cat "$MANIFEST"; exit 0; }

# Already at latest — just output and exit
if [ "$VERSION" = "$LATEST_VERSION" ]; then
  cat "$MANIFEST"
  exit 0
fi

# Chained migration: apply each step sequentially
python3 -c "
import json, sys

with open('$MANIFEST') as f:
    data = json.load(f)

version = data.get('version', '')
migrated_from = version

def migrate_1_0_to_1_1(data):
    data.setdefault('assessments', {'items': [], 'formative_checkpoints': [], 'feedback_quality_score': 0})
    data.setdefault('course_content', {'modules': [], 'generated_files': [], 'build_timestamp': ''})
    data.setdefault('import_metadata', {'source': '', 'imported_at': '', 'source_lms': '', 'items_imported': {'modules': 0, 'objectives': 0, 'assessments': 0, 'activities': 0, 'pages': 0}, 'quality_flags': 0})
    data.setdefault('export_metadata', {'exported_at': '', 'format': '', 'destination': '', 'items_exported': {'modules': 0, 'pages': 0, 'assignments': 0, 'quizzes': 0, 'discussions': 0}, 'failed_items': 0, 'notes': ''})
    qr = data.setdefault('quality_review', {})
    qr.setdefault('cross_domain_checks', {
        'cognitive_load':        {'score': 0, 'flags': []},
        'multimedia_principles': {'score': 0, 'flags': []},
        'feedback_quality':      {'score': 0, 'flags': []},
        'expertise_reversal':    {'score': 0, 'flags': []}
    })
    qr.setdefault('review_history', [])
    data['version'] = '1.1'
    return data

def migrate_1_1_to_1_2(data):
    # Add new sections for skills that now write to manifest
    data.setdefault('red_team_audit', {
        'updated': '',
        'confidence_score': 0,
        'findings_summary': {'critical': 0, 'warning': 0, 'info': 0},
        'dimensions': {},
        'top_actions': [],
        'limitations': []
    })
    data.setdefault('accessibility_review', {
        'updated': '',
        'score': {'overall': 0, 'wcag': 0, 'udl': 0},
        'wcag_violations': [],
        'udl_recommendations': [],
        'quick_wins': []
    })
    # Add readiness_check to export_metadata
    em = data.setdefault('export_metadata', {})
    # Convert failed_items from int (v1.1) to list (v1.2)
    if isinstance(em.get('failed_items'), int):
        em['failed_items'] = []
    em.setdefault('readiness_check', {
        'quality_score': 0,
        'quality_reviewed': False,
        'red_team_critical': 0,
        'red_team_reviewed': False,
        'accessibility_critical': 0,
        'accessibility_reviewed': False,
        'verdict': ''
    })
    # Add quick_wins and recommendations to quality_review
    qr = data.setdefault('quality_review', {})
    qr.setdefault('quick_wins', [])
    qr.setdefault('recommendations', [])
    qr.setdefault('overall_score', 0)
    qr.setdefault('score_breakdown', {
        'qm_structural': 0,
        'coi_presence': 0,
        'constructive_alignment': 0,
        'cross_domain_evidence': 0
    })
    data['version'] = '1.2'
    return data

def migrate_1_2_to_1_3(data):
    # Add preferences section for user configuration
    data.setdefault('preferences', {
        'verbosity': 'normal',
        'export_format': '',
        'preferred_lms': '',
        'auto_advance_pipeline': False
    })
    data['version'] = '1.3'
    return data

# Apply migrations in order
if version == '1.0':
    data = migrate_1_0_to_1_1(data)
    version = '1.1'

if version == '1.1':
    data = migrate_1_1_to_1_2(data)
    version = '1.2'

if version == '1.2':
    data = migrate_1_2_to_1_3(data)
    version = '1.3'

if version != '$LATEST_VERSION':
    # Unknown version — output unchanged
    with open('$MANIFEST') as f:
        print(f.read(), end='')
    sys.exit(0)

with open('$MANIFEST', 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')

print(json.dumps(data, indent=2))
print(f'MIGRATED {migrated_from} $LATEST_VERSION', file=sys.stderr)
" || { cat "$MANIFEST"; exit 0; }
